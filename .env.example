# ── Wallet ────────────────────────────────────────────────────────────────────
WALLET_PRIVATE_KEY=your_base58_private_key_here

# ── Solana RPC ─────────────────────────────────────────────────────────────────
RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_api_key_here
# Coinbase CDP (ganti baris di atas jika pakai CDP — Client API Key di path, bukan ?api-key=):
# RPC_URL=https://api.developer.coinbase.com/rpc/v1/solana-mainnet/your_cdp_client_api_key

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Option A: OpenRouter (default)
OPENROUTER_API_KEY=sk-or-your_openrouter_key_here

# Option B: LM Studio (local) — uncomment these and comment out OPENROUTER_API_KEY
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_API_KEY=lm-studio
# LLM_MODEL=your-model-name-from-lmstudio

# ── API Keys ───────────────────────────────────────────────────────────────────
HELIUS_API_KEY=your_helius_api_key_here

# ── Swarm (Beacon) ─────────────────────────────────────────────────────────────
GOROVER_SWARM_API_BASE=https://swarm.gorover.xyz
GOROVER_SCOUT_KEY=sc_your_scout_key_here
# `gorover-agent start` checks WALLET pubkey matches the Scout record on Swarm (app-registered wallet).
# Local emergency only: GOROVER_SKIP_SCOUT_WALLET_CHECK=1

# ── Jupiter referral ──────────────────────────────────────────────────────────
# Referral is embedded in the public Rover build.
# Override is intentionally NOT exposed for end-users.

# ── Telegram Notifications (optional) ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALLOWED_USER_IDS=

# ── Dangerous admin actions (disabled by default) ─────────────────────────────
ALLOW_SELF_UPDATE=false

# ── Misc ───────────────────────────────────────────────────────────────────────
DRY_RUN=true
LOG_LEVEL=info
